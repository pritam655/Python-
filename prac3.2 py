# Taking input from user
items = list(map(int, input("Enter item numbers separated by space: ").split()))

# a) Total number of items
print("Total number of items:", len(items))

# b) Last item in the list
print("Last item in the list:", items[-1])

# c) Sorted list
sorted_items = sorted(items)
print("Sorted list:", sorted_items)

# d) Check if 515 is present
if 515 in items:
    print("Yes")
else:
    print("No")

# e) Add 121 and 321, then sort and print
items.extend([121, 321])
items.sort()
print("Updated sorted list:", items)